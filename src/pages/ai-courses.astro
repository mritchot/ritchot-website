---
/**
 * /ai-courses/ — standalone hub recreated from the Bear page (Phase 3).
 * Unlisted: not in the nav; a real indexable page; outside the writing
 * collection so it never enters the stream or feeds.
 */
import Base from '../layouts/Base.astro';
import HubCollections from '../components/HubCollections.astro';
import InkDivider from '../components/InkDivider.astro';
---

<Base
  title="AI Courses · ritchot.me"
  description="The AI courses I build: each entry links to the course, its source, and any related writing."
>
  <h1>AI Courses</h1>
  <div class="hub">
    <p>
      This page collects the AI courses I build. Each entry links to the
      course, its source, and any related writing. Right now there is one.
    </p>

    <InkDivider />

    <article>
      <h2>AI Literacy for the Modern Workforce</h2>
      <p class="updated"><em>Last updated: July 2026</em></p>
      <p>
        A four-module interactive program that teaches AI literacy through
        mechanism rather than tool familiarity. It makes a case as to why AI
        literacy matters now in a corporate setting, and covers how language
        models actually tokenize text, predict the next token, and generate
        language, then builds the judgment to evaluate what those systems
        produce. It is aimed at mid-career knowledge workers and incorporates
        Anthropic's 4D AI Fluency framework (Delegation, Description,
        Discernment, Diligence). The platform is custom-coded rather than
        built in an off-the-shelf authoring tool, with a Kirkpatrick
        evaluation architecture and xAPI-aligned event tracking designed in
        from the start.
      </p>

      <HubCollections />
    </article>
  </div>
</Base>

<style>
  h1 {
    margin-block-end: 1.25rem;
  }

  .hub {
    max-width: var(--measure);
  }

  .hub p + p,
  .hub ul {
    margin-block-start: 0.9em;
  }

  .hub h2 {
    margin-block: 0.5rem 0.4rem;
  }

  .updated {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
  }




</style>
