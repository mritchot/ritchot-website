---
import TypeBadge from './TypeBadge.astro';
import { urlOf, formatDate, type Writing } from '../lib/writing';
import { readingTime } from '../lib/reading-time';

interface Props {
  entries: Writing[];
  /** tighter type and rhythm for the homepage hero column */
  compact?: boolean;
}

const { entries, compact = false } = Astro.props;
---

<ul class:list={['stream', { compact }]}>
  {
    entries.map((entry) => (
      <li>
        <a class="title" href={urlOf(entry)}>
          {entry.data.title}
        </a>
        <p class="meta">
          <span>{formatDate(entry.data.date)}</span>
          <span aria-hidden="true">·</span>
          <TypeBadge type={entry.data.type} />
          <span aria-hidden="true">·</span>
          <span>{readingTime(entry.body ?? '')} min read</span>
        </p>
      </li>
    ))
  }
</ul>

<style>
  .stream {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.6rem;
  }

  .title {
    font-size: var(--text-1);
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
  }

  .title:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--signal);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    margin-block-start: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* mobile: date / type / reading time on three lines (5c finding 12) */
  @media (max-width: 480px) {
    .meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }

    .meta > [aria-hidden] {
      display: none;
    }
  }

  .compact {
    gap: 0.95rem;
  }

  .compact .title {
    font-size: var(--text-0);
  }

  .compact .meta {
    margin-block-start: 0.2rem;
    font-size: 0.7rem;
  }
</style>
