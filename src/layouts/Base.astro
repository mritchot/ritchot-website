---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  ogImage?: string;
  /** ISO 8601; emitted as article:published_time on article pages. */
  publishedTime?: string;
  /** ISO 8601; emitted as article:modified_time on article pages. */
  modifiedTime?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  noindex = false,
  ogType = 'website',
  ogImage = '/og/default.png',
  publishedTime,
  modifiedTime,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Michael Ritchot',
  url: Astro.site?.href,
};
const structuredData = [personLd, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- D23: sets data-theme from localStorage before first paint (no FOUC).
         Synchronous by design; ~0.4 KB. External file per the CSP. -->
    <script src="/theme.js" is:inline></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="alternate" type="application/rss+xml" title="ritchot.me" href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title="ritchot.me (Atom)" href="/atom.xml" />
    <link rel="alternate" type="application/feed+json" title="ritchot.me (JSON)" href="/feed.json" />
    <meta property="og:site_name" content="ritchot.me" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {
      ogType === 'article' && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === 'article' && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl.href} />
    <meta name="twitter:image:alt" content={title} />
    <link
      rel="preload"
      href="/fonts/source-serif-4-latin-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      structuredData.map((data) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
      ))
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    padding: 2.5rem 1.25rem 2.75rem;
  }

  .skip-link {
    position: absolute;
    inset-inline-start: -100vw;
    inset-block-start: 0;
    z-index: 10;
    background: var(--ground);
    color: var(--signal);
    padding: 0.5rem 1rem;
  }

  .skip-link:focus {
    inset-inline-start: 0;
  }
</style>
