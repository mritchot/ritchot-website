---
import Base from '../../layouts/Base.astro';
import WritingList from '../../components/WritingList.astro';
import { sortedWriting, type Writing } from '../../lib/writing';

const entries = await sortedWriting();

const byYear = new Map<number, Writing[]>();
for (const entry of entries) {
  const year = entry.data.date.getUTCFullYear();
  const group = byYear.get(year);
  if (group) group.push(entry);
  else byYear.set(year, [entry]);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Writing · ritchot.me" description="Writing by Michael Ritchot.">
  <h1>Writing</h1>
  {
    years.map((year) => (
      <section>
        <h2 class="year">{year}</h2>
        <WritingList entries={byYear.get(year)!} />
      </section>
    ))
  }
</Base>

<style>
  h1 {
    margin-block-end: 1.5rem;
  }

  section {
    margin-block-start: 2.5rem;
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    font-weight: 400;
    color: var(--ink-soft);
    border-block-end: 1px solid var(--line);
    padding-block-end: 0.4rem;
    margin-block-end: 1.4rem;
  }
</style>
