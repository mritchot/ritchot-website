---
/**
 * Design-system specimen — Phase 1 review surface.
 * noindex, excluded from the sitemap, unlinked from navigation.
 * Scheduled for deletion before launch (TODO.md, Phase 6).
 */
import Base from '../layouts/Base.astro';
import InkDivider from '../components/InkDivider.astro';
import { contrastRatio } from '../lib/contrast';
import { highlight } from '../lib/code';
import faviconRaw from '../../public/favicon.svg?raw';

// Chips pin each ground's fill so both render side by side in either mode;
// the shipped favicon.svg swaps fills itself via prefers-color-scheme.
const faviconBare = faviconRaw.replace(/<style>.*?<\/style>/, '');

// Mirrors tokens.css (the source of truth). This page dies before launch;
// the duplication is accepted so ratios can be computed and printed at build.
const palette = {
  light: {
    ground: '#f7f4ef', surface: '#eeeae1', ink: '#1e1c19', 'ink-soft': '#57534b',
    'ink-faint': '#7d786e', line: '#d9d3c7', vermilion: '#c73b27', signal: '#0c6b76',
    ember: '#d95d1e', 'code-keyword': '#8d3423', 'code-string': '#3d6647',
    'code-constant': '#0c6b76', 'code-name': '#8a4d15', 'code-comment': '#6d6759',
  },
  dark: {
    ground: '#101014', surface: '#17171d', ink: '#e6e2d9', 'ink-soft': '#a49f93',
    'ink-faint': '#767268', line: '#2c2c34', vermilion: '#e05543', signal: '#4cc3d0',
    ember: '#e8763a', 'code-keyword': '#e57a68', 'code-string': '#86b28d',
    'code-constant': '#4cc3d0', 'code-name': '#d9a15e', 'code-comment': '#8b8578',
  },
} as const;

type TokenName = keyof typeof palette.light;

interface PairSpec {
  fg: TokenName;
  bg: TokenName;
  min: number | null;
  note: string;
}

const pairSpecs: PairSpec[] = [
  { fg: 'ink', bg: 'ground', min: 4.5, note: 'body text' },
  { fg: 'ink-soft', bg: 'ground', min: 4.5, note: 'secondary text' },
  { fg: 'signal', bg: 'ground', min: 4.5, note: 'links' },
  { fg: 'vermilion', bg: 'ground', min: 3, note: 'focus / accent (non-text)' },
  { fg: 'ink', bg: 'surface', min: 4.5, note: 'code plain text' },
  { fg: 'code-keyword', bg: 'surface', min: 4.5, note: 'code keywords' },
  { fg: 'code-string', bg: 'surface', min: 4.5, note: 'code strings' },
  { fg: 'code-constant', bg: 'surface', min: 4.5, note: 'code constants' },
  { fg: 'code-name', bg: 'surface', min: 4.5, note: 'code names' },
  { fg: 'code-comment', bg: 'surface', min: 4.5, note: 'code comments' },
  { fg: 'ink-faint', bg: 'ground', min: null, note: 'decorative only (divider)' },
  { fg: 'ember', bg: 'ground', min: null, note: 'hero / illustration only' },
];

const pairs = pairSpecs.map((p) => {
  const light = contrastRatio(palette.light[p.fg], palette.light[p.bg]);
  const dark = contrastRatio(palette.dark[p.fg], palette.dark[p.bg]);
  return {
    ...p,
    light,
    dark,
    pass: p.min === null || (light >= p.min && dark >= p.min),
  };
});

const scale = [
  { token: '--text-4', cls: 'size-4', rem: '2.4414rem', px: '46.4px' },
  { token: '--text-3', cls: 'size-3', rem: '1.9531rem', px: '37.1px' },
  { token: '--text-2', cls: 'size-2', rem: '1.5625rem', px: '29.7px' },
  { token: '--text-1', cls: 'size-1', rem: '1.25rem', px: '23.75px' },
  { token: '--text-0', cls: 'size-0', rem: '1rem', px: '19px' },
  { token: '--text--1', cls: 'size-m1', rem: '0.8rem', px: '15.2px' },
];

const codeHtml = highlight(
  `
// WCAG 2.x relative luminance, per channel
const channel = (v: number): number => {
  const c = v / 255;
  return c <= 0.04045 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
};

export function contrastRatio(fg: string, bg: string): number {
  const [hi, lo] = [luminance(fg), luminance(bg)].sort((a, b) => b - a);
  return (hi + 0.05) / (lo + 0.05);
}

const FLOOR = 4.5;
console.log(\`text floor: \${FLOOR}:1\`);
`,
  'typescript',
);

---

<Base title="Specimen · ritchot.me" description="Design-system specimen." noindex>
  <h1>Specimen</h1>
  <p class="note">
    Phase 1 review surface: tokens, type, chrome, code, wordmark. Not linked, not
    indexed, not in the sitemap; deleted before launch. Review in both color
    modes (system preference switches them).
  </p>

  <section>
    <h2>Tokens · contrast</h2>
    <p class="note">
      Ratios computed at build for both modes. Floors: 4.5:1 text, 3:1 non-text
      accent. Swatches render in the active mode.
    </p>
    <table class="contrast">
      <thead>
        <tr>
          <th></th>
          <th>pair</th>
          <th>light</th>
          <th>dark</th>
          <th>floor</th>
          <th>use</th>
        </tr>
      </thead>
      <tbody>
        {
          pairs.map((p) => (
            <tr>
              <td>
                <span class={`swatch fg-${p.fg} bg-${p.bg}`}>Aa</span>
              </td>
              <td>
                <code>
                  {p.fg}/{p.bg}
                </code>
              </td>
              <td>{p.light.toFixed(2)}:1</td>
              <td>{p.dark.toFixed(2)}:1</td>
              <td>{p.min === null ? '—' : `≥ ${p.min}`}</td>
              <td>
                {p.note} {p.min !== null && (p.pass ? '✓' : '✗')}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section>
    <h2>Type scale</h2>
    <p class="note">Modular scale ≈ 1.25 on a 19px base. Serif: Source Serif 4 (variable, 400–700 + italic).</p>
    <ul class="scale">
      {
        scale.map((s) => (
          <li>
            <code>
              {s.token} · {s.rem} · {s.px}
            </code>
            <span class={`sample ${s.cls}`}>Ink holds where water moved</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2>Prose · justified, hyphenated</h2>
    <div class="prose">
      <p>
        This site is set in ink on two grounds: a warm paper white borrowed
        from washi, and a near-black borrowed from sumi. Neither mode is an
        afterthought — the same scale of ink values is tuned for each ground,
        and every pairing you are reading has its contrast ratio measured at
        build time and printed above. Restraint is the organizing principle:
        one vermilion accent may appear in a viewport, links speak in a single
        teal signal, and everything else is ink.
      </p>
      <p>
        Body text is Source Serif 4 at nineteen pixels, justified with
        hyphenation enabled, on a measure of forty-two rems — roughly
        sixty-five to seventy characters. Justification here is the plain CSS
        baseline; a Knuth–Plass upgrade is measured in a later phase and ships
        only if it costs nothing perceptible. <em>Italics carry emphasis</em>,
        numerals like 1848 and 2026 sit in the running text, and
        characteristically overlong administrative vocabulary —
        internationalization, phenomenological, incomprehensibilities — gives
        the hyphenation engine something to break.
      </p>
      <p>
        The chrome around the prose speaks mono. Navigation, metadata,
        badges, and captions are set in IBM Plex Mono at the small step of the
        scale, which keeps the reading surface serif and the machine surface
        legible without competing. The seal-stamp monogram is the only piece
        of iconography, and it is drawn from the same ink as the text it
        signs.
      </p>
      <p>
        Nothing on this page executes in your browser. There are no trackers,
        no analytics beacons, no font services phoning home — the fonts are
        subset and served from this origin, the styles are static, and the
        strict content-security policy that enforces all of this is itself
        part of the design system: honesty as a constraint, not a slogan.
      </p>
    </div>
  </section>

  <section>
    <h2>Mono chrome</h2>
    <p class="note">Navigation with a current page, a metadata line, and type badges.</p>
    <nav class="demo-nav" aria-label="Demo">
      <span class="demo-home">ritchot.me</span>
      <span class="demo-links">
        <a class="current" href="#" aria-current="page">Writing</a>
        <a href="#">Projects</a>
        <a href="#">Resume</a>
        <a href="#">About</a>
      </span>
    </nav>
    <p class="meta-line">essay · 12 min read · 14 July 2026 · <span class="updated">updated 21 July 2026</span></p>
    <p class="badges">
      <span class="badge">essay</span>
      <span class="badge">analysis</span>
      <span class="badge">notes</span>
    </p>
  </section>

  <section>
    <h2>Code · build-time Shiki, token palette</h2>
    <p class="note">
      Class-based highlighting (no inline styles — the CSP forbids them);
      colors are the --code-* tokens, flipping with the mode.
    </p>
    <Fragment set:html={codeHtml} />
  </section>

  <section>
    <h2>Ink-stroke divider</h2>
    <InkDivider />
  </section>

  <section>
    <h2>Wordmark · favicon</h2>
    <p class="note">
      D16 final: purely typographic identity. Header scale and footer scale
      below; favicon is the Source Serif 4 "M" (wght 500) as a path-only SVG,
      shown at 16 / 32 / 64 on both grounds (chips pin each ground's fill —
      the shipped file swaps by system mode).
    </p>
    <p class="wordmark-header">Michael Ritchot</p>
    <p class="wordmark-footer">Michael Ritchot</p>
    <div class="fav-row">
      <span class="fav-chip chip-light">
        <span class="f16" set:html={faviconBare} />
        <span class="f32" set:html={faviconBare} />
        <span class="f64" set:html={faviconBare} />
      </span>
      <span class="fav-chip chip-dark">
        <span class="f16" set:html={faviconBare} />
        <span class="f32" set:html={faviconBare} />
        <span class="f64" set:html={faviconBare} />
      </span>
    </div>
  </section>
</Base>

<style>
  section {
    margin-block-start: 3rem;
  }

  h2 {
    font-family: var(--font-mono);
    font-size: var(--text-0);
    font-weight: 500;
    border-block-end: 1px solid var(--line);
    padding-block-end: 0.4rem;
  }

  .note {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    max-width: var(--measure);
    margin-block: 0.75rem;
  }

  /* contrast table */
  .contrast {
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: var(--text--1);
    width: 100%;
  }

  .contrast th {
    text-align: left;
    color: var(--ink-soft);
    font-weight: 400;
    border-block-end: 1px solid var(--line);
    padding: 0.3rem 0.75rem 0.3rem 0;
  }

  .contrast td {
    padding: 0.3rem 0.75rem 0.3rem 0;
    border-block-end: 1px solid var(--line);
  }

  .swatch {
    display: inline-grid;
    place-items: center;
    inline-size: 2.4rem;
    block-size: 1.7rem;
    border: 1px solid var(--line);
    font-family: var(--font-serif);
  }

  /* static token classes — the CSP (style-src 'self') forbids style attributes */
  .fg-ink { color: var(--ink); }
  .fg-ink-soft { color: var(--ink-soft); }
  .fg-ink-faint { color: var(--ink-faint); }
  .fg-signal { color: var(--signal); }
  .fg-vermilion { color: var(--vermilion); }
  .fg-ember { color: var(--ember); }
  .fg-code-keyword { color: var(--code-keyword); }
  .fg-code-string { color: var(--code-string); }
  .fg-code-constant { color: var(--code-constant); }
  .fg-code-name { color: var(--code-name); }
  .fg-code-comment { color: var(--code-comment); }
  .bg-ground { background: var(--ground); }
  .bg-surface { background: var(--surface); }

  .size-4 { font-size: var(--text-4); }
  .size-3 { font-size: var(--text-3); }
  .size-2 { font-size: var(--text-2); }
  .size-1 { font-size: var(--text-1); }
  .size-0 { font-size: var(--text-0); }
  .size-m1 { font-size: var(--text--1); }

  /* type scale */
  .scale {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .scale code {
    display: block;
    font-size: var(--text--1);
    color: var(--ink-soft);
  }

  .scale .sample {
    line-height: var(--leading-tight);
  }

  /* mono chrome samples */
  .demo-nav,
  .meta-line,
  .badges {
    font-family: var(--font-mono);
    font-size: var(--text--1);
  }

  .demo-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid var(--line);
    padding: 0.7rem 1rem;
    max-width: var(--measure);
  }

  .demo-home {
    font-weight: 500;
  }

  .demo-links {
    display: flex;
    gap: 1.1rem;
  }

  .demo-links a {
    position: relative;
    color: var(--ink-soft);
    text-decoration: none;
  }

  .demo-links a.current {
    color: var(--ink);
  }

  .demo-links a.current::after {
    content: '';
    position: absolute;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    inset-block-end: -0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--vermilion);
  }

  .meta-line {
    color: var(--ink-soft);
    margin-block: 1.1rem;
  }

  .meta-line .updated {
    font-style: italic;
  }

  .badge {
    display: inline-block;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    padding: 0.1em 0.55em;
    margin-inline-end: 0.4rem;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* wordmark + favicon */
  .wordmark-header {
    font-size: 1.1rem;
    font-weight: 500;
    margin-block: 0.9rem 0.3rem;
  }

  .wordmark-footer {
    font-size: var(--text--1);
    font-weight: 500;
    color: var(--ink-soft);
  }

  .fav-row {
    display: flex;
    gap: 1rem;
    margin-block-start: 1.1rem;
  }

  .fav-chip {
    display: flex;
    align-items: flex-end;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--line);
  }

  /* chips pin both grounds simultaneously, independent of the active mode */
  .chip-light { background: #f7f4ef; }
  .chip-light :global(path) { fill: #1c1b1a; }
  .chip-dark { background: #101014; }
  .chip-dark :global(path) { fill: #e6e2d8; }

  .fav-chip > span { display: block; }
  .f16 :global(svg) { width: 16px; height: 16px; display: block; }
  .f32 :global(svg) { width: 32px; height: 32px; display: block; }
  .f64 :global(svg) { width: 64px; height: 64px; display: block; }
</style>
