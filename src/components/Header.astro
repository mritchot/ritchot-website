---
const nav = [
  { href: '/writing', label: 'Writing' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/about', label: 'About' },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  path === href || path === `${href}/` || path.startsWith(`${href}/`);
---

<header>
  <nav aria-label="Site">
    <a class="home" href="/">ritchot.me</a>
    <ul>
      {
        nav.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  header {
    border-block-end: 1px solid var(--line);
  }

  nav {
    max-width: 52rem;
    margin-inline: auto;
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text--1);
  }

  .home {
    color: var(--ink);
    font-weight: 500;
    text-decoration: none;
  }

  ul {
    display: flex;
    gap: 1.1rem;
    list-style: none;
    padding: 0;
  }

  ul a {
    position: relative;
    color: var(--ink-soft);
    text-decoration: none;
  }

  ul a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  ul a[aria-current='page'] {
    color: var(--ink);
  }

  /* current page: small vermilion underline dot */
  ul a[aria-current='page']::after {
    content: '';
    position: absolute;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    inset-block-end: -0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--vermilion);
  }

  /* keep a single row on small screens — no hamburger, no JS */
  @media (max-width: 420px) {
    nav {
      font-size: 0.72rem;
      gap: 0.75rem;
    }

    ul {
      gap: 0.75rem;
    }
  }
</style>
