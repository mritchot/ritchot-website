---
import { parse } from 'yaml';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { externalAttrs } from '../lib/rehype-external-links';
import raw from '../data/resume.yaml?raw';

interface Link {
  label: string;
  url: string;
}
interface Experience {
  title: string;
  org: string;
  location: string;
  period: string;
  bullets: string[];
}
interface EducationNote {
  text: string;
  url?: string;
}
interface Education {
  degree: string;
  school: string;
  location: string;
  year: string;
  url?: string;
  notes: EducationNote[];
}
interface CertItem {
  name: string;
  issuer: string;
  year: string;
  url?: string;
  sublinks?: { label: string; url: string }[];
}
interface CertGroup {
  group: string;
  items: CertItem[];
}
interface Resume {
  name: string;
  contact: {
    email: string;
    location: string;
    linkedin: string;
    github: string;
    website: string;
  };
  summary: string;
  competencies: string[];
  featured: { title: string; links: Link[]; bullets: string[] };
  experience: Experience[];
  education: Education[];
  certifications: CertGroup[];
}

const resume = parse(raw) as Resume;
const { name, contact, summary, competencies, featured, experience, education, certifications } = resume;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  email: `mailto:${contact.email}`,
  url: new URL('/resume/', Astro.site).href,
  sameAs: [contact.linkedin, contact.github],
};
---

<Base
  title="Resume · Michael Ritchot"
  description="Resume of Michael Ritchot — AI enablement and learning & development professional."
  jsonLd={[personLd]}
>
  <article class="resume">
    <header class="head">
      <!-- name is print-only on the web view: the site header carries it -->
      <h1 class="name">{name}</h1>
      <p class="contact">
        <span class="item"><Icon name="pin" />{contact.location}</span>
        <span aria-hidden="true">·</span>
        <!-- email is print-only: the web page has never carried it -->
        <span class="item print-only">
          <Icon name="envelope" /><a href={`mailto:${contact.email}`}>{contact.email}</a>
        </span>
        <span aria-hidden="true" class="print-only">·</span>
        <span class="item">
          <Icon name="linkedin" /><a href={contact.linkedin} {...externalAttrs(contact.linkedin)}>LinkedIn</a>
        </span>
        <span aria-hidden="true">·</span>
        <span class="item">
          <Icon name="github" /><a href={contact.github} {...externalAttrs(contact.github)}>GitHub</a>
        </span>
        <span aria-hidden="true">·</span>
        <span class="item">
          <Icon name="globe" /><a href={contact.website} {...externalAttrs(contact.website)}>Website</a>
        </span>
      </p>
      <p class="download">
        <a href="/resume.pdf">Download PDF ↓</a>
      </p>
    </header>

    <section aria-labelledby="rs-summary">
      <h2 id="rs-summary">Summary</h2>
      <p class="summary">{summary}</p>
    </section>

    <section aria-labelledby="rs-competencies">
      <h2 id="rs-competencies">Core competencies</h2>
      <ul class="competencies">
        {competencies.map((c) => <li>{c}</li>)}
      </ul>
    </section>

    <section aria-labelledby="rs-featured">
      <h2 id="rs-featured">
        Featured project<span class="fdash" aria-hidden="true"> — </span>
        <span class="ftitle">{featured.title}</span>
      </h2>
      <ul class="bullets">
        {featured.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <p class="featured-links">
        {featured.links.map((l) => <a href={l.url} {...externalAttrs(l.url)}>{l.label} ↗</a>)}
      </p>
    </section>

    <section aria-labelledby="rs-experience">
      <h2 id="rs-experience">Experience</h2>
      {
        experience.map((job) => (
          <div class="entry">
            <h3>{job.title}</h3>
            <p class="meta">
              <strong>{job.org}</strong>
              <span aria-hidden="true">·</span>
              <span>{job.location}</span>
              <span aria-hidden="true">·</span>
              <span class="period">{job.period}</span>
            </p>
            {job.bullets.length > 0 && (
              <ul class="bullets">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </section>

    <section aria-labelledby="rs-education">
      <h2 id="rs-education">Education</h2>
      {
        education.map((ed) => (
          <div class="entry">
            <h3>{ed.url ? <a class="doc" href={ed.url}>{ed.degree}</a> : ed.degree}</h3>
            <p class="meta">
              <strong>{ed.school}</strong>
              <span aria-hidden="true">·</span>
              <span>{ed.location}</span>
              <span aria-hidden="true">·</span>
              <span class="period">{ed.year}</span>
            </p>
            {ed.notes.length > 0 && (
              <ul class="bullets">
                {ed.notes.map((n) => (
                  <li>{n.url ? <a class="doc" href={n.url}>{n.text}</a> : n.text}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </section>

    <section aria-labelledby="rs-certifications">
      <h2 id="rs-certifications">Certifications</h2>
      {
        certifications.map((group) => (
          <div class="certgroup">
            <h3>{group.group}</h3>
            <ul class="certs">
              {group.items.map((c) => (
                <li>
                  <span class="cname">
                    {c.url ? <a class="doc" href={c.url}>{c.name}</a> : c.name}
                    {c.sublinks && (
                      <>
                        {' '}
                        {c.sublinks.map((l, i) => (
                          <>
                            {i > 0 && (i === c.sublinks!.length - 1 ? ', and ' : ', ')}
                            <a class="doc" href={l.url}>{l.label}</a>
                          </>
                        ))}
                      </>
                    )}
                  </span>
                  <span class="csep" aria-hidden="true"> — </span>
                  <span class="cissuer">{c.issuer}</span>
                  <span class="csep" aria-hidden="true"> · </span>
                  <span class="cyear">{c.year}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>
  </article>
</Base>

<style>
  .resume {
    max-width: var(--measure);
  }

  /* print-only name (5b finding 15): the site header already carries it
     on the web; screen readers still get it */
  .name {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .contact {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* icon sits beside its label, baseline-ish, and never wraps away from it */
  .contact .item {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
  }

  .contact .print-only {
    display: none;
  }

  .download {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    margin-block-start: 1.1rem;
  }

  .download a {
    border: 1px solid var(--line);
    padding: 0.4rem 0.8rem;
    text-decoration: none;
    display: inline-block;
  }

  .download a:hover {
    border-color: var(--signal);
  }

  section {
    margin-block-start: 2.6rem;
  }

  h2 {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    border-block-end: 1px solid var(--line);
    padding-block-end: 0.4rem;
    margin-block-end: 1.2rem;
  }

  .summary,
  .competencies {
    text-wrap: pretty;
  }

  .competencies {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    line-height: 1.8;
    list-style: none;
    padding: 0;
  }

  .competencies li {
    display: inline;
  }

  .competencies li + li::before {
    content: ' · ';
  }

  /* mobile: one competency per line (5d B1) */
  @media (max-width: 480px) {
    .competencies li {
      display: block;
    }

    .competencies li + li::before {
      content: none;
    }
  }

  /* mobile: "Featured project" and the title on separate lines, no dash
     (5d B2) */
  @media (max-width: 480px) {
    .fdash {
      display: none;
    }

    .ftitle {
      display: block;
    }
  }

  .entry {
    margin-block-start: 1.5rem;
  }

  .entry:first-of-type {
    margin-block-start: 0;
  }

  h3 {
    font-size: var(--text-0);
    font-weight: 600;
  }

  .meta {
    font-size: var(--text--1);
    color: var(--ink-soft);
    margin-block-start: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* mobile: org / location / period stack cleanly (5c finding 13) */
  @media (max-width: 480px) {
    .meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .meta > [aria-hidden] {
      display: none;
    }
  }

  .period {
    font-family: var(--font-mono);
  }

  .bullets {
    margin-block-start: 0.6rem;
    padding-inline-start: 1.15rem;
    display: grid;
    gap: 0.45rem;
  }

  .bullets li {
    text-wrap: pretty;
  }

  .featured-links {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    margin-block-start: 0.9rem;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .certgroup {
    margin-block-start: 1.2rem;
  }

  .certgroup:first-of-type {
    margin-block-start: 0;
  }

  .certs {
    margin-block-start: 0.5rem;
    padding-inline-start: 1.15rem;
    display: grid;
    gap: 0.3rem;
    font-size: var(--text--1);
  }

  /* mobile: title / company / date on three lines, company and date
     hanging at the title's text start past the marker (5d B3) */
  @media (max-width: 480px) {
    .certs {
      gap: 0.65rem;
    }

    .certs .csep {
      display: none;
    }

    .certs .cname,
    .certs .cissuer,
    .certs .cyear {
      display: block;
    }

    .certs .cissuer,
    .certs .cyear {
      color: var(--ink-soft);
    }
  }

  /* --- print: a clean document, hard two-page maximum (§5, 5b G4) --- */
  @media print {
    .resume {
      max-width: none;
    }

    .download {
      display: none;
    }

    /* the name returns in print */
    .name {
      position: static;
      width: auto;
      height: auto;
      overflow: visible;
      clip-path: none;
      white-space: normal;
      font-size: 15pt;
    }

    :global(html) {
      font-size: 8.5pt;
    }

    :global(body) {
      line-height: 1.35;
    }

    .contact,
    .meta,
    .competencies,
    .featured-links,
    .certs,
    h2 {
      color: #333;
    }

    /* links persist as clickable annotations, colored with the
       light-mode link color per the 5d ruling */
    a[href] {
      color: #0c6b76;
      text-decoration: none;
    }

    .contact {
      margin-block-start: 0.35rem;
    }

    /* the email returns in print (17-07-2026 ruling) */
    .contact .print-only {
      display: inline-flex;
    }

    section {
      margin-block-start: 0.5rem;
    }

    h2 {
      margin-block-end: 0.4rem;
      padding-block-end: 0.2rem;
      border-color: #bbb;
    }

    h3 {
      font-size: 0.95rem;
    }

    .meta {
      margin-block-start: 0.15rem;
    }

    /* nothing starts on one page and continues on the next */
    .head,
    .entry,
    .certgroup,
    section[aria-labelledby='rs-summary'],
    section[aria-labelledby='rs-competencies'],
    section[aria-labelledby='rs-featured'] {
      break-inside: avoid;
    }

    .entry,
    .certgroup {
      margin-block-start: 0.4rem;
    }

    .bullets {
      display: block;
      margin-block-start: 0.3rem;
      padding-inline-start: 1.05rem;
    }

    .bullets li {
      display: list-item;
      list-style: disc outside;
      margin-block-start: 0.1rem;
    }

    /* the subset webfont has no U+2022; markers borrow a full system
       serif so the disc actually renders in the PDF */
    .bullets li::marker {
      font-family: Georgia, 'Times New Roman', serif;
    }

    .competencies {
      line-height: 1.5;
    }

    .certs {
      margin-block-start: 0.25rem;
      gap: 0.1rem;
      font-size: 0.76rem;
    }

    .featured-links {
      margin-block-start: 0.5rem;
    }
  }
</style>
