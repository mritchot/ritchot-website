---
/**
 * Homepage hero (§4.8 as amended; restructured per the 5b desktop review,
 * 15-07-2026): fills the viewport under the header, and the page's content
 * lives ON the field — identity line top-left (x-aligned with the header
 * wordmark), latest writing left column, selected project right column.
 * No name in the hero (the wordmark is the identity), no scroll cue; the
 * footer sits one small scroll below the fold.
 *
 * Legibility over live ink: soft ground-tint panels under each content
 * zone — ratified 5d as sufficient on their own. Pours land anywhere,
 * including directly behind the panels; no clearing zones, no pour bias.
 *
 * The typographic page remains the permanent state: no-JS, reduced motion,
 * island failure, and lost GL contexts keep the plain panels on the ground.
 */
---

<section id="hero" class="hero">
  <div class="inner">
    <h1 class="sr-only">Michael Ritchot</h1>
    <p class="line">I lift, love music, and play with tech.</p>
    <div class="columns">
      <div class="col">
        <h2>Latest writing</h2>
        <slot name="latest" />
        <p class="more"><a href="/writing/">All writing</a></p>
      </div>
      <div class="col">
        <h2>Selected project</h2>
        <slot name="project" />
        <p class="more"><a href="/projects/">All projects</a></p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    /* fills main's track exactly: on desktop the body is pinned to the
       viewport (5c finding 1) so header + hero + footer are one screen */
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    color: var(--ink);
    display: flex;

    /* the hero is where ember lives (light); vermilion trace in dark */
    --hero-accent: var(--ember);
  }

  /* short desktop viewports: the body pin releases (see index.astro), so
     the hero takes a viewport-height minimum and the page scrolls — the
     composition is never clipped (5d desktop finding) */
  @media (min-width: 761px) and (max-height: 699px) {
    .hero {
      height: auto;
      min-height: calc(100svh - 3.65rem);
    }
  }

  /* mobile scrolls naturally: full-bleed out of main's padded column,
     full-viewport field, natural growth */
  @media (max-width: 760px) {
    .hero {
      width: 100vw;
      margin-inline: calc(50% - 50vw);
      margin-block-start: -2.5rem;
      min-height: calc(100svh - 3.65rem);
      height: auto;
    }
  }

  /* dual-path with the D23 toggle: system dark unless forced light,
     plus forced dark */
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .hero {
      --hero-accent: var(--vermilion);
    }
  }

  :global(:root[data-theme='dark']) .hero {
    --hero-accent: var(--vermilion);
  }

  @media (max-width: 480px) {
    .hero {
      min-height: calc(100svh - 5.9rem);
      height: auto;
    }
  }

  .hero :global(canvas.sumi) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 700ms ease;
    pointer-events: none;
  }

  .hero :global(canvas.sumi.ready) {
    opacity: 1;
  }

  /* the content column matches the header's, so the identity line
     x-aligns with the wordmark */
  .inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    padding: 1.9rem 1.25rem 2rem;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* every panel bleeds by exactly its own inline padding, so panel TEXT
     sits on the identity line's x-grid at every width (5c finding 3) */
  .line {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--ground) 82%, transparent);
    box-shadow: 0 0 0.9rem 0.55rem color-mix(in srgb, var(--ground) 82%, transparent);
    padding: 0.35rem 0.75rem;
    margin-inline-start: -0.75rem;
  }

  /* top-aligned, higher in the field (5c finding 2) */
  .columns {
    margin-block-start: clamp(1.75rem, 8svh, 4.25rem);
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: start;
  }

  .col {
    /* feathered ground panel: guaranteed contrast with no hard edge
       against a dense pour */
    background: color-mix(in srgb, var(--ground) 86%, transparent);
    box-shadow: 0 0 1.2rem 0.8rem color-mix(in srgb, var(--ground) 86%, transparent);
    padding: 1rem 0.75rem 1.05rem;
    margin-inline: -0.75rem;
  }

  .col h2 {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    font-weight: 400;
    color: var(--ink-soft);
    border-block-end: 1px solid var(--line);
    padding-block-end: 0.4rem;
    margin-block-end: 1.1rem;
  }

  .more {
    margin-block-start: 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--text--1);
  }

  @media (max-width: 760px) {
    .columns {
      grid-template-columns: 1fr;
      align-items: stretch;
    }
  }
</style>

<script>
  // island: dissolving ink over the plain page. Mounts only once the page
  // is fully loaded AND idle — the reader settles in first, then the ink
  // arrives through its crossfade. Every failure path simply leaves the
  // typographic page.
  const start = () => {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    import('../islands/suminagashi/index')
      .then((m) => {
        const host = document.getElementById('hero');
        if (host) m.mountSuminagashi(host);
      })
      .catch(() => {
        /* the plain page remains */
      });
  };
  const idle = () => {
    if ('requestIdleCallback' in window) requestIdleCallback(start);
    else setTimeout(start, 350);
  };
  if (document.readyState === 'complete') idle();
  else window.addEventListener('load', idle, { once: true });
</script>
