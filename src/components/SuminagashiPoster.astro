---
/**
 * Frozen ink-dissolution poster — a still of the live field (D21, revised at
 * the 4b addendum: the marbling-ring art is retired). LCP element and the
 * permanent no-JS / reduced-motion / island-failure state (§4.8).
 * Soft radial pigment blooms in the live token inks; the lower-left stays
 * clear for the overlay. Hand-authored; matte by construction.
 */
---

<svg
  class="poster"
  viewBox="0 0 1600 1000"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <radialGradient id="sp-ink" cx="0.42" cy="0.44" r="0.62">
      <stop offset="0" stop-color="var(--ink)" stop-opacity="0.55"></stop>
      <stop offset="0.75" stop-color="var(--ink)" stop-opacity="0.12"></stop>
      <stop offset="1" stop-color="var(--ink)" stop-opacity="0"></stop>
    </radialGradient>
    <radialGradient id="sp-accent" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="var(--hero-accent)" stop-opacity="0.5"></stop>
      <stop offset="0.55" stop-color="var(--hero-accent)" stop-opacity="0.26"></stop>
      <stop offset="1" stop-color="var(--hero-accent)" stop-opacity="0"></stop>
    </radialGradient>
    <radialGradient id="sp-murasaki" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="var(--murasaki)" stop-opacity="0.42"></stop>
      <stop offset="0.6" stop-color="var(--murasaki)" stop-opacity="0.2"></stop>
      <stop offset="1" stop-color="var(--murasaki)" stop-opacity="0"></stop>
    </radialGradient>
    
    <linearGradient id="sp-signal" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="var(--signal)" stop-opacity="0"></stop>
      <stop offset="0.3" stop-color="var(--signal)" stop-opacity="0.34"></stop>
      <stop offset="0.72" stop-color="var(--signal)" stop-opacity="0.22"></stop>
      <stop offset="1" stop-color="var(--signal)" stop-opacity="0"></stop>
    </linearGradient>
    
  </defs>

  <!-- main sumi bloom, upper-centre-left, dissolving outward -->
  <ellipse cx="640" cy="380" rx="470" ry="380" fill="url(#sp-ink)" transform="rotate(-9 640 380)"></ellipse>

  <!-- accent bloom (ember on washi, vermilion on sumi) -->
  <ellipse cx="1150" cy="255" rx="225" ry="185" fill="url(#sp-accent)" transform="rotate(7 1150 255)"></ellipse>
  <!-- signal wisp crossing beneath the main bloom -->
  <ellipse cx="920" cy="585" rx="330" ry="48" fill="url(#sp-signal)" transform="rotate(-6 920 585)"></ellipse>
  <!-- murasaki bloom at the lower-right horizon -->
  <ellipse cx="1370" cy="750" rx="240" ry="190" fill="url(#sp-murasaki)" transform="rotate(-14 1370 750)"></ellipse>
  <ellipse cx="1015" cy="150" rx="80" ry="66" fill="var(--ink)" fill-opacity="0.18"></ellipse>
  <!-- faint flecks -->
  <circle cx="420" cy="120" r="26" fill="var(--ink)" fill-opacity="0.12"></circle>
  <circle cx="1490" cy="470" r="18" fill="var(--ink)" fill-opacity="0.1"></circle>
</svg>

<style>
  .poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
