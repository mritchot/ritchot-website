---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import WritingList from '../components/WritingList.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { sortedWriting } from '../lib/writing';
import { sortedProjects } from '../lib/projects';

const latest = (await sortedWriting()).slice(0, 4);
const selected = (await sortedProjects())[0];
---

<Base title="Michael Ritchot" description="Writing by Michael Ritchot.">
  <Hero>
    <WritingList entries={latest} compact slot="latest" />
    {selected && <ProjectCard project={selected} compact slot="project" />}
  </Hero>
</Base>

<style is:global>
  /* 5c finding 1 / 5d follow-up — the homepage is one true screen on
     desktop WHEN THE COMPOSITION FITS: the body is a min-height-100svh
     flex column (Base), so main stretches to fill the remaining viewport
     and the hero fills main. When the viewport is too short for the
     content, the flex chain simply grows past the viewport and the page
     scrolls — no height pin, no overflow clip, no threshold; clipping is
     structurally impossible at any size. Mobile scrolls naturally. */
  @media (min-width: 761px) {
    main#main {
      display: flex;
      flex-direction: column;
      min-height: 0;
      padding: 0;
      max-width: none;
    }
  }

  /* 5d mobile finding: the field runs to the footer boundary — no dead
     band of bare ground under the last panel */
  @media (max-width: 760px) {
    main#main {
      padding-block-end: 0;
    }
  }
</style>
