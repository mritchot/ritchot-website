---
// Horizontal brush-stroke divider. Decorative only; colored --ink-faint via
// currentColor. Used sparingly: between homepage sections and above footers.
---

<div class="ink-divider" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 12" preserveAspectRatio="none" fill="currentColor">
    <path
      d="M2 6.8 C38 3.2 92 8.6 158 6.2 C236 3.4 318 8.2 394 5.4 L397 6.2 C330 9.6 252 5.8 172 8.4 C104 10.4 48 6.4 3 8.6 Z" />
    <ellipse cx="386" cy="9.4" rx="3.4" ry="0.9" />
    <ellipse cx="12" cy="4.2" rx="2.2" ry="0.7" />
  </svg>
</div>

<style>
  .ink-divider {
    color: var(--ink-faint);
    max-width: var(--measure);
    margin-block: 2.5rem;
  }

  .ink-divider svg {
    width: 100%;
    height: 0.5rem;
  }
</style>
