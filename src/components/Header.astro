---
const nav = [
  { href: '/writing', label: 'Writing' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/about', label: 'About' },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  path === href || path === `${href}/` || path.startsWith(`${href}/`);
---

<header>
  <nav aria-label="Site">
    <a class="home" href="/" aria-label="Michael Ritchot">
      <span class="full" aria-hidden="true">Michael Ritchot</span>
      <span class="short" aria-hidden="true">M.&nbsp;Ritchot</span>
    </a>
    <ul>
      {
        nav.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))
      }
      <li>
        <!-- D23 toggle: statically reserved (no layout shift), invisible
             until /theme.js wires it; with JS off it never appears. -->
        <button class="theme-toggle" type="button" aria-label="Theme">◐</button>
      </li>
    </ul>
  </nav>
</header>

<style>
  header {
    border-block-end: 1px solid var(--line);
  }

  nav {
    max-width: 52rem;
    margin-inline: auto;
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text--1);
  }

  /* serif wordmark (D16 final) — sized ≈ nav cap-height × 1.4 */
  .home {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--ink);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }

  /* the full name wraps below ~560px next to the nav links: swap to the
     short mark there. The <480px stacked layout gets the full name back. */
  .short {
    display: none;
  }

  @media (min-width: 481px) and (max-width: 600px) {
    .full {
      display: none;
    }

    .short {
      display: inline;
    }
  }

  ul {
    display: flex;
    gap: 1.1rem;
    list-style: none;
    padding: 0;
  }

  ul a {
    position: relative;
    color: var(--ink-soft);
    text-decoration: none;
  }

  ul a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  ul a[aria-current='page'] {
    color: var(--ink);
  }

  /* current page: small vermilion underline dot */
  ul a[aria-current='page']::after {
    content: '';
    position: absolute;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    inset-block-end: -0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--vermilion);
  }

  /* small screens: wordmark row over nav row (Maverick, 14-07-2026) —
     still no hamburger, no JS; nav keeps its size and single row */
  @media (max-width: 480px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.55rem;
      padding-block: 0.8rem;
    }
  }
</style>
