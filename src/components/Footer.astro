---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

// Copyright range: earliest published piece through the current build year.
// UTC to match the collection's date handling (formatDate pins timeZone: UTC),
// so a frontmatter date never slips a year in a negative-offset timezone.
const entries = await getCollection('writing');
const firstYear = Math.min(...entries.map((e) => e.data.date.getUTCFullYear()));
const buildYear = new Date().getFullYear();
const years = firstYear === buildYear ? `${firstYear}` : `${firstYear}–${buildYear}`;

// self-hosted inline marks (5b finding 4): official simple paths on a
// 24×24 viewBox, filled with currentColor — no icon font, no CDN
const social = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/mritchot', icon: 'linkedin' },
  { label: 'GitHub', href: 'https://github.com/mritchot', icon: 'github' },
  { label: 'X', href: 'https://x.com/MichaelRitchot', icon: 'x' },
] as const;
---

<footer>
  <div class="inner">
    <p class="left">
      <a href="/subscribe">Subscribe</a>
      <span class="social">
        {
          social.map(({ label, href, icon }) => (
            <a href={href} aria-label={label} target="_blank" rel="noopener noreferrer">
              <Icon name={icon} />
            </a>
          ))
        }
      </span>
    </p>
    <p class="rights">© {years} Michael Ritchot. Site code MIT.</p>
  </div>
</footer>

<style>
  footer {
    border-block-start: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
  }

  /* compact (5c finding 4): one tight row — it shares the single-screen
     homepage with the hero */
  .inner {
    max-width: 52rem;
    margin-inline: auto;
    padding: 0.9rem 1.25rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .left {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .left > a {
    color: var(--ink-soft);
  }

  .left > a:hover {
    color: var(--ink);
  }

  .rights {
    font-size: 0.7rem;
  }

  .social {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .social a {
    color: var(--ink-soft);
    display: inline-flex;
  }

  .social a:hover {
    color: var(--ink);
  }
</style>
