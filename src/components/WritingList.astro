---
import TypeBadge from './TypeBadge.astro';
import { urlOf, formatDate, type Writing } from '../lib/writing';
import { readingTime } from '../lib/reading-time';

interface Props {
  entries: Writing[];
}

const { entries } = Astro.props;
---

<ul class="stream">
  {
    entries.map((entry) => (
      <li>
        <a class="title" href={urlOf(entry)}>
          {entry.data.title}
        </a>
        <p class="meta">
          {formatDate(entry.data.date)}
          <span aria-hidden="true">·</span>
          <TypeBadge type={entry.data.type} />
          <span aria-hidden="true">·</span>
          {readingTime(entry.body ?? '')} min read
        </p>
      </li>
    ))
  }
</ul>

<style>
  .stream {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.6rem;
  }

  .title {
    font-size: var(--text-1);
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
  }

  .title:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--signal);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    margin-block-start: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
