---
import { urlOf, type Project } from '../lib/projects';

interface Props {
  project: Project;
  /** borderless, tighter variant for the homepage hero column */
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { title, summary, period, stack } = project.data;
---

<article class:list={['card', { compact }]}>
  <p class="meta">{period}</p>
  <h3 class="title">
    <a href={urlOf(project)}>{title}</a>
  </h3>
  <p class="summary">{summary}</p>
  <p class="stack">{stack.join(' · ')}</p>
</article>

<style>
  .card {
    border: 1px solid var(--line);
    padding: 1.4rem 1.5rem 1.3rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }


  .title {
    font-size: var(--text-1);
    margin-block-start: 0.55rem;
  }

  .title a {
    color: var(--ink);
    text-decoration: none;
  }

  .title a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--signal);
  }

  .summary {
    margin-block-start: 0.55rem;
    color: var(--ink-soft);
    text-wrap: pretty;
  }

  .stack {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    color: var(--ink-soft);
    margin-block-start: 0.8rem;
  }

  .compact {
    border: none;
    padding: 0;
  }

  .compact .title {
    font-size: var(--text-0);
  }

  .compact .summary {
    font-size: var(--text--1);
    line-height: 1.55;
  }

  .compact .stack {
    font-size: 0.7rem;
  }
</style>
