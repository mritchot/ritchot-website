---
import Base from '../layouts/Base.astro';
import EmailSubscribe from '../components/EmailSubscribe.astro';
---

<Base
  title="Subscribe · ritchot.me"
  description="Follow new writing by feed reader — full-text RSS, Atom, and JSON."
>
  <article class="subscribe prose">
    <h1>Subscribe</h1>
    <!-- All copy below flagged for gate approval (Phase 5 Part D). -->
    <p>
      Point a feed reader of your choice at any of the URLs below and new
      pieces arrive as I post them:
    </p>
    <ul class="feeds">
      <li><a href="/feed.xml">ritchot.me/feed.xml</a> — RSS</li>
      <li><a href="/atom.xml">ritchot.me/atom.xml</a> — Atom</li>
      <li><a href="/feed.json">ritchot.me/feed.json</a> — JSON</li>
    </ul>
    <EmailSubscribe />
  </article>
</Base>

<style>
  .subscribe {
    max-width: var(--measure);
  }

  h1 {
    margin-block-end: 1.5rem;
  }

  .feeds {
    font-family: var(--font-mono);
    font-size: var(--text--1);
    list-style: none;
    display: grid;
    gap: 0.5rem;
    border: 1px solid var(--line);
    padding: 1rem 1.25rem;
  }
</style>
